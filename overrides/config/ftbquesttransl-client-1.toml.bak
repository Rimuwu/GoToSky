#Target language for translation (ISO 639-1 code).
#Set to 'auto' to use Minecraft's language setting.
#Examples: uk, ru, de, fr, es, ja, zh, ko, pl, pt
targetLanguage = "russian"
#Enable translation caching to avoid re-translating the same text.
#Cached translations are stored in memory for the current session.
enableCaching = true
#Translation API provider.
#AUTO - Automatic fallback: Google -> DoH bypass -> Lingva -> MyMemory (recommended)
#GOOGLE - Google Translate (unofficial, free, no key needed)
#MYMEMORY - MyMemory API (free, 5000 chars/day limit)
#DEEPL - DeepL API (requires deepLApiKey)
#Allowed Values: AUTO, GOOGLE, MYMEMORY, DEEPL
translationProvider = "AUTO"
#Enable the yellow wave animation while a quest is being translated.
enableTranslatingAnimation = true
#Enable the green wave animation when a quest has been translated.
enableTranslatedAnimation = true
#Warn before translating quests with very large text to prevent accidental API quota usage.
enableLargeTextWarning = true
#The character count threshold used to trigger the large text warning.
largeTextThreshold = 2000
